{
	"name": "multi-tenant-asset-service",
	"version": "1.0.0",
	"description": "Multy-Tenant Asset Management Service",
	"main": "server.js",
	"scripts": {
		"dev": "tsx --watch --env-file .env.development src/server.ts",
		"start": "node --env-file .env.production dist/server.js",
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
		"type-check": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest",
		"test:run": "vitest --run",
		"test:ui": "vitest --ui",
		"coverage": "vitest run --coverage",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"eslint",
			"prettier --check"
		],
		"*.{json,yml,yaml,md}": [
			"prettier --check"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/szafeiris/multi-tenant-asset-service.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"type": "module",
	"bugs": {
		"url": "https://github.com/szafeiris/multi-tenant-asset-service/issues"
	},
	"homepage": "https://github.com/szafeiris/multi-tenant-asset-service#readme",
	"dependencies": {
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tsconfig/node22": "^22.0.5",
		"@types/express": "^5.0.6",
		"@types/node": "^25.9.2",
		"@vitest/coverage-v8": "^4.1.8",
		"@vitest/eslint-plugin": "^1.6.20",
		"@vitest/ui": "^4.1.8",
		"eslint": "^10.4.1",
		"eslint-plugin-perfectionist": "^5.9.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.4",
		"tsc-alias": "^1.8.17",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8"
	}
}
