meta {
  name: Refresh
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/refresh
  body: none
  auth: bearer
}

auth:bearer {
  token: {{refreshToken}}
}


script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("refreshToken", res.body.refreshToken);
  }
}
