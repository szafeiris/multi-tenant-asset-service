PORT=5000

# Logging
LOG_LEVEL=info
LOG_PATH=logs

JWT_SECRET=super_secret_jwt_key_example
JWT_ACCESS_EXPIRATION=5m
JWT_REFRESH_EXPIRATION=1h

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=asset_service
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=asset_service
